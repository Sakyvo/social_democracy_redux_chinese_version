@party
title: 党务
card-image: img/Vorwaerts_nr_1.png
is-deck: true

- #party_affairs

@govt
title: 政务
view-if: time >= 6 or spd_in_government
card-image: img/reichstag_2.jpg
is-deck: true

- #govt_affairs

@pres
title: 总统事务
view-if: president == "Braun" or president == "Schumacher" or president == "Juchacz"
card-image: img/presidential_affairs.jpg
is-deck: true

- #pres_affairs
