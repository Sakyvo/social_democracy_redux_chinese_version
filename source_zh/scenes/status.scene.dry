title: 状态
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
!}

= 状态

[+ month : month +] [+ year +] 年

可用资源：[+ resources +]

社民党立场：[? if spd_toleration : 容忍政府 ?][? if spd_in_government : 执政 — ?][? if spd_toleration == 0 and spd_in_government == 0 and spd_caretaker == 0 : 反对派 ?][? if spd_caretaker : 看守政府 ?]
[? if in_weimar_coalition and spd_in_government: 魏玛联合 ?][? if in_grand_coalition and spd_in_government: 大联合 ?][? if in_popular_front and spd_in_government: 人民阵线 ?][? if in_left_front and spd_in_government: 左翼阵线 ?][? if in_spd_majority and spd_in_government: 社民党多数 ?][? if in_minority_government and spd_in_government: 少数派政府 ?][? if in_emergency_government and spd_in_government: 紧急政府 ?]

[? if spd_in_government and not in_spd_majority and not in_left_front : 联合政府不满：[+ coalition_dissent : coalition_dissent +] ?]

[? if spd_in_government and (in_left_front or in_popular_front): 德共联合不满：[+ kpd_coalition_dissent : coalition_dissent +] ?]

党内不满：[+ dissent_percent : dissent +]

[? if communist_influence_seen : 德共影响力：[+ kpd_influence : kpd_influence +] ?]

= 政府

总统：[+ president +]

[? if president == "Marx" : 总统关系：[+ marx_relation : relationships +] ?]

总理：[+ chancellor +]（[+ chancellor_party +]）

国会席位构成：

# 1928: 30, 1930: 25, 1932: 22
SPD：[+ spd_r +]%
[? if sapd_formed == 1 : SAPD：[+ sapd_r +]% ?]
# 1928: 15, 1930: 15, 1932:
Z + BVP：[+ z_r +]%
# 1928: 10, 1930: 13
KPD：[+ kpd_r +]%
# 1928: 5, 1930: 4 (as DstP)
DDP：[+ ddp_r +]%
# 1928: 9, 1930: 5
DVP：[+ dvp_r +]%
# 1928: 14, 1930: 7
DNVP：[+ dnvp_r +]%
# 1928: 3, 1930: 18
NSDAP：[+ nsdap_r +]%
# 1928: 9, 1930: 10
其他：[+ other_r +]%

[? if spd_in_government = 1 : 预算：[+ budget +] ?]

下次选举：[+ next_election_year +] 年 [+ next_election_month : month +]

= 经济

通货膨胀：[+ inflation_2 +]%

[? if black_thursday_seen = 1 : 失业率：[+ unemployed_2 +]% ?]

经济增长：[+ economic_growth_2 +]%


