= 社民党内部派系

左派实力：[+ left_strength : strength +]，不满：[+ left_dissent : dissent +]

中间派实力：[+ center_strength : strength +]，不满：[+ center_dissent : dissent +]

工会派实力：[+ labor_strength : strength +]，不满：[+ labor_dissent : dissent +]

改良派实力：[+ reformist_strength : strength +]，不满：[+ reformist_dissent : dissent +]

[? if neorevisionism > 0 : 新修正派实力：[+ neorevisionist_strength : strength +]，不满：[+ neorevisionist_dissent : dissent +] ?]


@paramilitaries
on-arrival: {!
if (Q.rb_strength) {
    Q.rb_strength_2 = Q.rb_strength.toFixed(1);
}
if (Q.rfb_strength) {
    Q.rfb_strength_2 = Q.rfb_strength.toFixed(1);
}
if (Q.sh_strength) {
    Q.sh_strength_2 = Q.sh_strength.toFixed(1);
}
if (Q.sa_strength) {
    Q.sa_strength_2 = Q.sa_strength.toFixed(1);
}
!}

= 武装力量分布

冲锋队（SA）：[+ sa_force +]%

钢盔团（Stahlhelm）：[+ sh_force +]%

黑红金国旗团（Reichsbanner）：[+ rb_force +]%

红色阵线战士同盟（RFB）：[+ rfb_force +]%

普鲁士：[+ prussia_force +]%

国防军（Reichswehr）：[+ army_force +]%

= 准军事组织

黑红金国旗团兵力：[+ rb_strength_2 +] 千人

黑红金国旗团军事化程度：[+ rb_militancy : militancy +]

红色阵线战士同盟兵力：[+ rfb_strength_2 +] 千人

红色阵线战士同盟军事化程度：[+ rfb_militancy : militancy +]

钢盔团兵力：[+ sh_strength_2 +] 千人

钢盔团军事化程度：[+ sh_militancy : militancy +]

冲锋队兵力：[+ sa_strength_2 +] 千人

冲锋队军事化程度：[+ sa_militancy : militancy +]

= 官方军队与准军事力量

国防军：[+ reichswehr_strength +] 千名士兵。

国防军忠诚度：[+ reichswehr_loyalty : loyalty +]

普鲁士警察：[+ prussian_police_strength +] 千人。

普鲁士警察忠诚度：[+ prussian_police_loyalty : loyalty +]

[? if spd_in_government : 内政警察忠诚度：[+ interior_police_loyalty : loyalty +] ?]

@polls
on-arrival: {!
Q.pro_republic_disp = Math.round(Q.pro_republic);
Q.nationalism_disp = Math.round(Q.nationalism);
Q.socialism_disp = Math.round(Q.socialism);
!}

