旧中产阶级：SPD：[+ old_middle_spd_display +]%，[? if sapd_formed == 1 : SAPD：[+ old_middle_sapd_display +]%， ?] Z：[+ old_middle_z_display +]%，KPD：[+ old_middle_kpd_display +]%，DDP：[+ old_middle_ddp_display +]%，DVP：[+ old_middle_dvp_display +]%；DNVP：[+ old_middle_dnvp_display +]%，[? if dne_formed : DNE：[+ old_middle_dne_display +]%， ?] NSDAP：[+ old_middle_nsdap_display +]%，其他：[+ old_middle_other_display +]%

农村：SPD：[+ rural_spd_display +]%，[? if sapd_formed == 1 : SAPD：[+ rural_sapd_display +]%， ?] Z：[+ rural_z_display +]%，KPD：[+ rural_kpd_display +]%，DDP：[+ rural_ddp_display +]%，DVP：[+ rural_dvp_display +]%；DNVP：[+ rural_dnvp_display +]%，[? if dne_formed : DNE：[+ rural_dne_display +]%， ?] NSDAP：[+ rural_nsdap_display +]%，其他：[+ rural_other_display +]%

失业者：SPD：[+ unemployed_spd_display +]%，[? if sapd_formed == 1 : SAPD：[+ unemployed_sapd_display +]%， ?] Z：[+ unemployed_z_display +]%，KPD：[+ unemployed_kpd_display +]%，DDP：[+ unemployed_ddp_display +]%，DVP：[+ unemployed_dvp_display +]%；DNVP：[+ unemployed_dnvp_display +]%，[? if dne_formed : DNE：[+ unemployed_dne_display +]%， ?] NSDAP：[+ unemployed_nsdap_display +]%，其他：[+ unemployed_other_display +]%

