民族主义支持率：[+ nationalism_disp +]%

工人：SPD：[+ workers_spd_display +]%，[? if sapd_formed == 1 : SAPD：[+ workers_sapd_display +]%， ?] Z：[+ workers_z_display +]%，KPD：[+ workers_kpd_display +]%，DDP：[+ workers_ddp_display +]%，DVP：[+ workers_dvp_display +]%；DNVP：[+ workers_dnvp_display +]%，[? if dne_formed : DNE：[+ workers_dne_display +]%， ?] NSDAP：[+ workers_nsdap_display +]%，其他：[+ workers_other_display +]%

