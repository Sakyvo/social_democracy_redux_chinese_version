            "name": Q.ddp_name,
            "seats": Math.round(Q.ddp_schl*0.15),
        },
        {
            "id": "dvp",
            "legend": "DVP",
            "name": "DVP",
            "seats": Math.round(Q.dvp_schl*0.15),
        },
        {
            "id": "other",
            "legend": "Other",
            "name": "Other",
