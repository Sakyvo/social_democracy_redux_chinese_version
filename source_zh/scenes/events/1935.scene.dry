title: 1935
subtitle: 新的一年
new-page: true
tags: event
priority: 2
view-if: year >= 1935 and month >= 1
max-visits: 1
on-arrival: older_republic = old_republic; old_republic = pro_republic; {!
if (Q.economic_growth < 5) {
    Q.economic_growth += 0.4;
    if (Q.works_program) {
        Q.economic_growth += 1;
        Q.inflation += 0.2;
    }
    if (Q.inflation < 5) {
        Q.inflation += 0.3;
        if (Q.works_program) {
            Q.inflation += 0.2;
        }
    }
}
if (Q.unemployed >= 15 && Q.economic_growth >= 2) {
    Q.unemployed -= Q.economic_growth;
    if (Q.works_program) {
        Q.unemployed -= (Q.economic_growth/2);
    }
} else if (Q.unemployed >= 15) {
    Q.unemployed -= 2;
    if (Q.works_program) {
        Q.unemployed -= 1;
    }
} else {
    Q.economic_growth += 1;
    if (Q.works_program) {
        Q.economic_growth += 0.6;
        Q.inflation += 0.4;
    }
}
if (Q.economic_growth >= 3) {
    Q.budget += 1;
    if ((Q.upper_taxes_rates+Q.lower_tax_rates) >= 6) {
        Q.budget += 1;
        Q.economic_growth -= ((Q.upper_tax_rates+(Q.lower_tax_rates/2))/12);
    }
}
if (Q.pro_republic > 75 && Q.pro_republic > Q.older_republic) {
    Q.new_middle_ddp += (Q.pro_republic - Q.older_republic)
    Q.old_middle_ddp += ((Q.pro_republic - Q.older_republic)/2)
    Q.new_middle_dvp += ((Q.pro_republic - Q.older_republic)/2)
    Q.old_middle_dvp += (Q.pro_republic - Q.older_republic)
}
!}

新的一年开始了。全世界范围内，大萧条正走向终结，其影响在德国本土也开始显现。[? if economic_growth > 3 : 考虑到全球仍处于衰退之中，德国经济的增长速度已令人瞩目。 ?][? if unemployed < 15 : 随着全国各地的人们重返工作岗位，失业率已大幅下降。 ?][? if inflation > 1 and inflation < 4 : 通胀维持在健康区间，既为经济提供了动力，也有助于进一步压低失业率。 ?]

[? if return_to_normalcy : 纳粹党似乎已错过了颠覆议会政治的窗口，转而进入内部重整时期。[? if sa_force + sh_force >= 50 : 然而，他们仍有可能在绝望中孤注一掷、以武力夺权。我们必须保持警惕。 ?] ?]