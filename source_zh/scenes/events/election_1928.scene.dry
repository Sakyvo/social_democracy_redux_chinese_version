@no_majority_bracht
on-arrival: {!
var hitler_points = 0;
var braun_points = 0;
var bruning_points = 0;

hitler_points += Q.nsdap_r;
hitler_points += Q.nationalism;
hitler_points += Q.anti_democratic_coalition;
hitler_points -= Q.sa_force;
hitler_points += Q.kpd_r;
hitler_points -= Q.marx_relation;

braun_points += Q.spd_r;
braun_points += Q.socialism;
braun_points += Q.pro_republic;
braun_points += Q.weimar_coalition;
braun_points -= Q.rb_force;
braun_points += Q.marx_relation;
braun_points -= Q.kpd_relation;
braun_points += Q.dvp_relation;

bruning_points += Q.z_r;
bruning_points += Q.neo_weimar_coalition;
bruning_points += Q.pro_republic;
bruning_points += (100-Q.socialism);
bruning_points += (100-Q.nationalism);
bruning_points -= Q.no_majority_elections;
if (braun_points >= hitler_points) {
    bruning_points += hitler_points/4;
} else {
    bruning_points += braun_points/4;
}

Q.braun_chosen = 0;
Q.hitler_chosen = 0;
Q.bruning_chosen = 0;

if (braun_points >= hitler_points && braun_points >= bruning_points) {
    Q.braun_chosen = 1;
} else if (hitler_points >= braun_points && hitler_points >= bruning_points) {
    Q.hitler_chosen = 1;
} else {
    Q.bruning_chosen = 1;
}
!}

