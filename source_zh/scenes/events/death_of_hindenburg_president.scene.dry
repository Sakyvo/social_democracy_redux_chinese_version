@r2_start
on-arrival: {!
// 1. coordination between the right/far-right
if (Q.Hitler_votes && Q.Seldte_votes) {
    if (Q.Hitler_votes > Q.Seldte_votes) {
        Q.dnvp_candidate = "Hitler";
        Q.other_candidate = "Hitler";
        Q.Hitler_bonus = (Q.Hitler_bonus || 0) - ((Q.pro_republic)/125)*Q.other_normalized; 
        if (Q.z_candidate == "Adenauer") {
            Q.Adenauer_bonus = (Q.Adenauer_bonus || 0) + ((Q.pro_republic)/125)*Q.other_normalized;
        }
    } else {
        Q.nsdap_candidate = "Seldte";
    }
} else if (Q.Goring_votes && Q.Seldte_votes) {
    if (Q.Goring_votes > Q.Seldte_votes) {
        Q.dnvp_candidate = "Göring";
        Q.other_candidate = "Göring";
    } else {
        Q.nsdap_candidate = "Seldte";
    }
}
// 2. If Adenauer & Gessler are both running and neither are part of the SPD coalition, the smaller of these drops out.
Q.adenauer_drops_out = 0;
Q.gessler_drops_out = 0;
if (Q.z_candidate == "Adenauer" && (Q.ddp_candidate == "Gessler" || Q.dvp_candidate == "Gessler") && Q.z_candidate != Q.spd_candidate && (Q.ddp_candidate != Q.spd_candidate || Q.dvp_candidate != Q.spd_candidate)) {
    if (Q.Adenauer_votes > Q.Gessler_votes) {
        Q.gessler_drops_out = 1;
        if (Q.ddp_candidate != Q.spd_candidate) {
            Q.ddp_candidate = "Adenauer";
        }
        if (Q.dvp_candidate != Q.spd_candidate) {
            Q.dvp_candidate = "Adenauer";
        }
        Q.Adenauer_bonus = (Q.Adenauer_bonus || 0) + 0.25*Q.other_normalized;
        // todo: make it dynamic rather than 25%
    } else {
        Q.adenauer_drops_out = 1;
        Q.z_candidate = "Gessler";
        Q.Gessler_bonus = 0.25*Q.other_normalized;
    }
}
// DVP drops out to favor the center candidate
if (Q.dvp_candidate != Q.spd_candidate && Q.dvp_candidate != Q.ddp_candidate && Q.dvp_candidate != Q.z_candidate) {
}
!}
go-to: r2_menu

领先者是 [+ winner_desc +]。第一轮没有过半多数。第二轮中，得票最多者将最终胜出。

[? if dnvp_candidate = "Hitler" : DNVP与NSDAP已整合选举力量，DNVP现已在第二轮为希特勒背书。一些右翼选民对此安排不安，或可能弃票。 ?]
[? if dnvp_candidate = "Göring" : DNVP与NSDAP已整合选举力量，DNVP现已在第二轮为戈林背书。 ?]
[? if nsdap_candidate = "Seldte" : DNVP与NSDAP已整合选举力量，NSDAP现已在第二轮为塞尔德特背书。 ?]

[? if gessler_drops_out : 自由派候选人奥托·盖斯勒已退出选战，转而背书中央党的康拉德·阿登纳。这整合了温和资产阶级集团的选票。 ?]
[? if adenauer_drops_out : 中央党候选人康拉德·阿登纳已退出选战，转而背书DStP-DVP候选人奥托·盖斯勒。这整合了温和资产阶级集团的选票。 ?]

我们该如何行动？

@r2_menu

# convince DDP/DVP/Z/KPD to endorse our candidate
# change the endorsement, if they aren't endorsing our candidate
# campaign

- @r2_endorse_thalmann
- @r2_endorse_munzenberg
- @r2_endorse_adenauer
- @r2_endorse_gessler
- @r2_endorse_eckener
