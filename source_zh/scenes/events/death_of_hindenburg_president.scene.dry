@kpd_resources
view-if: kpd_relation >= 50 and not historical_mode
choose-if: resources >= 3
subtitle: -3 resources
unavailable-subtitle: Not enough resources (need 3).
on-arrival: resources -= 3; kpd_candidate = spd_candidate; sapd_candidate = spd_candidate;
go-to: r1_menu if round = 0; r2_campaigning if round > 0

共产党现在为 [+ spd_candidate +] 背书参选总统！我们请他们将支持保持低调，以免疏远资产阶级选民。

@kpd_relations
view-if: kpd_relation >= 60 or (kpd_party_leader == "Conciliators" and kpd_relation >= 45)
unavailable-subtitle: Our relations are not good enough.
on-arrival: kpd_candidate = spd_candidate; sapd_candidate = spd_candidate;
go-to: r1_menu if round = 0; r2_campaigning if round > 0

共产党现在为 [+ spd_candidate +] 背书参选总统！我们请他们将支持保持低调，以免疏远资产阶级选民。


@convince_dvp_spd
title: 说服德国人民党支持 [+ spd_candidate +]。
unavailable-subtitle: The DVP is not willing to support our candidate.
view-if: spd_candidate = "Braun" or spd_candidate = "Schumacher" or spd_candidate = "Juchacz" or is_cultural_candidate
choose-if: (dvp_relation >= 50 and candidate != "Juchacz") or (dvp_relation >= 60 and candidate = "Juchacz")
on-arrival: dvp_candidate = spd_candidate
go-to: r1_menu if round = 0; r2_campaigning if round > 0
max-visits: 1

[? if dvp_candidate = spd_candidate: 凭借良好关系，DVP被说服支持 [+ spd_candidate +]！ ?]

@convince_dvp_unity
title: 说服德国人民党支持 [+ spd_candidate +]。
unavailable-subtitle: The DVP is not willing to support our candidate.
view-if: (spd_candidate = "Adenauer" or spd_candidate = "Gessler" or spd_candidate = "Eckener") and dvp_candidate != spd_candidate
choose-if: dvp_relation >= 40
on-arrival: dvp_candidate = spd_candidate
go-to: r1_menu if round = 0; r2_campaigning if round > 0
max-visits: 1

[? if dvp_candidate = spd_candidate: 凭借良好关系，加之我党候选人是与社民党无关的统一候选人，DVP被说服支持 [+ spd_candidate +]。 ?]



@round_1
go-to: election_algorithm
set-jump: post_election


@post_election
on-arrival: {!
var candidate_descs = {
Hitler: "Adolf Hitler of the NSDAP",
Goring: "Hermann Göring of the NSDAP",
Seldte: "Franz Seldte of the Stahlhelm/DNVP",
Eckener: "the independent republican candidate Hugo Eckener",
Adenauer: "Konrad Adenauer of the Center Party",
Gessler: "Otto Gessler, independent formerly of the DDP",
Thalmann: "Ernst Thälmann of the KPD",
Munzenberg: "Willi Münzenberg of the KPD",
Braun: "Otto Braun of the SPD",
Schumacher: "Kurt Schumacher of the SPD",
Juchacz: "Marie Juchacz of the SPD",
Einstein: "Albert Einstein, scientist",
Mann: "Heinrich Mann, writer",
Ossietzky: "Carl von Ossietzky, journalist"
}
for (var k in candidate_descs) {
    Q[k + '_running'] = 0;
}
var candidate_votes = {};
for (var i = 0; i < Q.parties.length; i++) {
    var party = Q.parties[i];
    var supported_candidate = Q[party + '_candidate'];
    console.log(party, supported_candidate);
    supported_candidate = supported_candidate.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    Q[supported_candidate + '_running'] = 1;
    if (supported_candidate in candidate_votes) {
        candidate_votes[supported_candidate] += Q[party+'_normalized'];
    } else {
        candidate_votes[supported_candidate] = Q[party+'_normalized'];
    }
}
var total_votes = 0;
Q.winner = "";
Q.winner_votes = 0;
Q.has_majority = 0;
for (var k in candidate_votes) {
    if (Q[k + '_bonus']) {
        candidate_votes[k] += Q[k + '_bonus']/100;
    }
    if (k == "Hitler" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        if (Q.nsdap_votes+Q.sa_force > Q.dnvp_votes+Q.other_votes+Q.sh_force) {
            candidate_votes[k] += (Q.nationalism/1000);
        } else {
            candidate_votes[k] += (Q.nationalism/2250);
        }
        candidate_votes[k] += ((100-Q.pro_republic)/1000);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Goring" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += ((10-Q.pacifism)/200);
        candidate_votes[k] += ((100-Q.pro_republic)/1000);
        if (Q.nsdap_votes+Q.sa_force > Q.dnvp_votes+Q.other_votes+Q.sh_force) {
            candidate_votes[k] += (Q.nationalism/2250);
        } else {
            candidate_votes[k] += (Q.nationalism/3500);
        }
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Seldte" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += ((10-Q.democratization)/150);
        if (Q.nsdap_votes+Q.sa_force <= Q.dnvp_votes+Q.other_votes+Q.sh_force) {
            candidate_votes[k] += (Q.nationalism/1750);
        } else {
            candidate_votes[k] += (Q.nationalism/2500);
        }
        if (Q.nsdap_candidate == "Seldte") {
            candidate_votes[k] += (Q.nationalism/1250);
        }
        candidate_votes[k] += ((100-Q.pro_republic)/1000);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Eckener" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += (Q.nationalism/1000);
        candidate_votes[k] += (Q.pro_republic/1000);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Adenauer" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += ((100-Q.nationalism)/1000);
        candidate_votes[k] += (Q.pro_republic/1000);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Gessler" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += ((10-Q.pacifism)/400);
        candidate_votes[k] += (Q.nationalism/2250);
        candidate_votes[k] += (Q.pro_republic/1000);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Thalmann" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += (Q.pacifism/250);
        candidate_votes[k] += ((100-Q.pro_republic)/1500);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Munzenberg" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += (Q.democratization/90);
        candidate_votes[k] += ((100-Q.pro_republic)/1750);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Braun" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += (Q.democratization/100);
        candidate_votes[k] += (Q.pro_republic/1000);
        candidate_votes[k] += ((100-Q.nationalism)/2500);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Schumacher" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += (Q.pacifism/200);
        candidate_votes[k] += (Q.pro_republic/1000);
        candidate_votes[k] += ((100-Q.nationalism)/2250);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Juchacz" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        if (Q.homosexual_rights) {
            candidate_votes[k] += ((Q.womens_rights+Q.homosexual_rights)/150);
        }
        candidate_votes[k] += (Q.pro_republic/1000);
        candidate_votes[k] += ((100-Q.nationalism)/2500);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Einstein" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += (Q.education_science/10);
        candidate_votes[k] += (Q.pro_republic/2500);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Mann" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += (Q.socialism/1000);
        candidate_votes[k] += (Q.pro_republic/2000);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    if (k == "Ossietzky" && Q[k+'_running']) {
        console.log(k, "votes before bonus:", candidate_votes[k]);
        candidate_votes[k] += (Q.pacifism/175);
        candidate_votes[k] += (Q.pro_republic/2250);
        candidate_votes[k] += ((Math.floor(Math.random() * 11))/350);
        console.log(k, "votes after bonus:", candidate_votes[k]);
    }
    total_votes += candidate_votes[k];
    if (candidate_votes[k] > Q.winner_votes) {
        Q.winner = k;
        Q.winner_votes = candidate_votes[k];
    }
}
for (var k in candidate_votes) {
    Q[k + '_votes'] = Math.round(1000*candidate_votes[k]/total_votes)/10;
    Q[k + '_votes_disp'] = Q[k + '_votes'].toFixed(1);
}
Q.winner_votes = Math.round(1000*(Q.winner_votes/total_votes))/10;
Q.winner_votes_disp = Q.winner_votes.toFixed(1);
Q.winner_desc = candidate_descs[Q.winner];
if (Q.winner_votes > 50) {
    Q.has_majority = 1;
}

Q.round += 1
!}
go-to: r2_start if round = 1 and not has_majority; election_end if round > 1; r1_winner if has_majority

Election results:

